rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // Phase 3: Primitives
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isSignedIn() { return request.auth != null; }
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }
    
    // Admin check: either in admins collection or matching a specific email (for bootstrap)
    function isAdmin() { 
      return isSignedIn() && (
        exists(/databases/$(database)/documents/admins/$(request.auth.uid)) ||
        request.auth.token.email == 'magicmind.verse@gmail.com'
      ); 
    }

    // Phase 4: Entity Validations
    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email', 'displayName']) &&
             data.uid is string && data.email is string && data.displayName is string;
    }

    function isValidCreation(data) {
      return data.keys().hasAll(['userId', 'type', 'createdAt']) &&
             data.userId == request.auth.uid &&
             data.type in ['image', 'audio'];
    }

    function isValidSupportMessage(data) {
      return data.keys().hasAll(['email', 'subject', 'message', 'createdAt']) &&
             data.email is string && data.subject is string && data.message is string;
    }

    // Match Blocks
    match /users/{userId} {
      allow get: if isSignedIn();
      allow list: if isAdmin();
      allow create: if isOwner(userId) && isValidUser(incoming());
      allow update: if (isOwner(userId) || isAdmin()) && isValidUser(incoming());
      allow delete: if isAdmin();
    }

    match /creations/{creationId} {
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid || isAdmin();
      allow get: if isOwner(resource.data.userId) || isAdmin();
      allow create: if isSignedIn() && isValidCreation(incoming());
      allow update: if (isOwner(resource.data.userId) || isAdmin()) && isValidCreation(incoming());
      allow delete: if isOwner(resource.data.userId) || isAdmin();
    }

    match /support_messages/{messageId} {
      allow list, get: if isAdmin();
      allow create: if isValidSupportMessage(incoming());
      allow update, delete: if isAdmin();
    }

    match /admins/{adminId} {
      allow read: if isSignedIn();
      allow write: if false;
    }
  }
}
